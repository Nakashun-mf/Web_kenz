# ==============================================================
# 図面検図アプリ — Apache 2.4 設定ファイル
# このファイルはビルド成果物に含まれます。編集不要です。
#
# 【導入先での前提条件】
#   Apache の VirtualHost または Directory ブロックに以下が必要です
#   （一度だけ設定、以降のバージョンアップでは不要）:
#     AllowOverride All
# ==============================================================


# ── SPA ルーティング ────────────────────────────────────────────
# 実ファイル・ディレクトリ以外のリクエストを index.html へリダイレクト
# （ブックマーク・リロード時の 404 を防止）
<IfModule mod_rewrite.c>
    RewriteEngine On

    # 実在するファイル・ディレクトリはそのまま返す
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # それ以外は index.html へ（.htaccess 配置ディレクトリを自動検出）
    RewriteRule ^ index.html [L]
</IfModule>


# ── MIME タイプ ─────────────────────────────────────────────────
# .mjs が未登録だと PDF.js Worker が動作しない（必須設定）
<IfModule mod_mime.c>
    AddType application/javascript  .mjs
    AddType application/javascript  .js
    AddType text/css                .css
    AddType image/svg+xml           .svg
    AddType application/font-woff2  .woff2
    AddType application/font-woff   .woff
    AddType application/json        .json
</IfModule>


# ── セキュリティヘッダー ────────────────────────────────────────
<IfModule mod_headers.c>

    # MIME スニッフィング防止
    Header always set X-Content-Type-Options "nosniff"

    # クリックジャッキング防止（同一オリジンの iframe のみ許可）
    Header always set X-Frame-Options "SAMEORIGIN"

    # Referrer 情報をオリジンのみに限定
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # 不要なブラウザ機能を無効化
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # Content Security Policy
    #   unsafe-eval  : PDF.js が内部で使用
    #   blob:        : PDF.js Web Worker の生成
    #   unsafe-inline: Tailwind CSS の動的スタイル
    Header always set Content-Security-Policy \
        "default-src 'self'; \
         script-src 'self' 'unsafe-eval'; \
         worker-src 'self' blob:; \
         img-src 'self' blob: data:; \
         style-src 'self' 'unsafe-inline'; \
         font-src 'self' data:; \
         object-src 'none'; \
         base-uri 'self'; \
         form-action 'self';"

    # サーバー情報の隠蔽
    Header always unset X-Powered-By
    Header always unset Server

</IfModule>


# ── 圧縮（gzip） ────────────────────────────────────────────────
# 1.2MB の JS バンドルを約 430KB に圧縮して転送
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE \
        text/html \
        text/css \
        application/javascript \
        application/json \
        image/svg+xml \
        application/font-woff2
</IfModule>


# ── キャッシュ制御 ──────────────────────────────────────────────
<IfModule mod_headers.c>

    # index.html: 常に最新版を確認（バージョンアップが即時反映される）
    <Files "index.html">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma         "no-cache"
        Header set Expires        "0"
    </Files>

    # Vite がビルドごとにファイル名へハッシュを埋め込むため
    # コンテンツが同じ限り 1 年間ブラウザキャッシュを利用できる
    # 例: index-CYLnHL01.js, index-CipyoHZi.css
    <FilesMatch "\.[0-9a-f]{8,}\.(js|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # PDF.js Worker（バージョン固定のため 30 日キャッシュ）
    <FilesMatch "pdf\.worker.*\.mjs$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    # SVG アイコン: 7 日キャッシュ
    <FilesMatch "\.(svg|ico)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>

</IfModule>


# ── ディレクトリ一覧を無効化 ────────────────────────────────────
# ファイル一覧が外部に見えないようにする
Options -Indexes


# ── サーバー署名を無効化 ────────────────────────────────────────
# エラーページからの Apache バージョン漏洩を防止
ServerSignature Off
